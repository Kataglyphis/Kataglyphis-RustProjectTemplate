<?xml version='1.0' encoding='windows-1252'?>
<!--
  Kataglyphis Rust Project Template
  WiX installer configuration for cargo-wix
  
  This file is used by cargo-wix to generate MSI installers.
  See: https://volks73.github.io/cargo-wix/
-->
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='Kataglyphis Rust Project Template'
        UpgradeCode='E8B9F4A1-2C3D-4E5F-A6B7-8C9D0E1F2A3B'
        Manufacturer='Kataglyphis'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='Rust project template with optional GUI, ONNX backends, profiling, packaging, and CI workflows.'
            Manufacturer='Kataglyphis'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'
            />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='Kataglyphis Rust Project Template Installation'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='ProgramFiles64Folder' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='Kataglyphis Rust Project Template'>
                    <!--
                      Uncomment to add a subdirectory for binaries:
                      <Directory Id='Bin' Name='bin'>
                    -->
                </Directory>
            </Directory>
            <Directory Id='ProgramMenuFolder'>
                <Directory Id='ApplicationProgramsFolder' Name='Kataglyphis Rust Project Template'/>
            </Directory>
        </Directory>

        <DirectoryRef Id='APPLICATIONFOLDER'>
            <Component Id='License' Guid='*' Win64='yes'>
                <File Id='LicenseFile'
                    Name='License.rtf'
                    DiskId='1'
                    Source='wix\License.rtf'
                    KeyPath='yes'/>
            </Component>
            
            <Component Id='binary0' Guid='*' Win64='yes'>
                <File
                    Id='exe0'
                    Name='kataglyphis_rustprojecttemplate.exe'
                    DiskId='1'
                    Source='target\release\kataglyphis_rustprojecttemplate.exe'
                    KeyPath='yes'/>
            </Component>
        </DirectoryRef>

        <DirectoryRef Id='ApplicationProgramsFolder'>
            <Component Id='ApplicationShortcut' Guid='*' Win64='yes'>
                <Shortcut Id='ApplicationStartMenuShortcut'
                    Name='Kataglyphis Rust Project Template'
                    Description='Rust project template with optional GUI, ONNX backends, profiling, packaging, and CI workflows.'
                    Target='[!exe0]'
                    WorkingDirectory='APPLICATIONFOLDER'/>
                <RemoveFolder Id='CleanUpShortCut' Directory='ApplicationProgramsFolder' On='uninstall'/>
                <RegistryValue Root='HKCU' Key='Software\Kataglyphis\RustProjectTemplate' Name='installed' Type='integer' Value='1' KeyPath='yes'/>
            </Component>
        </DirectoryRef>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs all binaries and the license.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>
            
            <ComponentRef Id='License'/>
            <ComponentRef Id='binary0'/>

            <Feature
                Id='StartMenu'
                Title='Start Menu Shortcuts'
                Description='Adds a shortcut to the Start menu.'
                Level='1'
                Absent='allow'>
                <ComponentRef Id='ApplicationShortcut'/>
            </Feature>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <!--
          Uncomment to add an icon for Add/Remove Programs:
        -->
        <!--
        <Icon Id='ProductICO' SourceFile='wix\Product.ico'/>
        <Property Id='ARPPRODUCTICON' Value='ProductICO' />
        -->

        <Property Id='ARPHELPLINK' Value='https://github.com/Kataglyphis/Kataglyphis-RustProjectTemplate'/>
        
        <UI>
            <UIRef Id='WixUI_FeatureTree'/>
            <!--
              Disable the EULA dialog by commenting this out:
            -->
            <Publish Dialog='WelcomeDlg' Control='Next' Event='NewDialog' Value='CustomizeDlg' Order='99'>1</Publish>
            <Publish Dialog='CustomizeDlg' Control='Back' Event='NewDialog' Value='WelcomeDlg' Order='99'>1</Publish>
        </UI>

        <!--
          Disable the license agreement by uncommenting:
        -->
        <!--
        <WixVariable Id='WixUILicenseRtf' Value='wix\License.rtf'/>
        -->

    </Product>

</Wix>
