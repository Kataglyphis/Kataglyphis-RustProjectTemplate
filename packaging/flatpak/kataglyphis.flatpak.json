{
  "app-id": "io.kataglyphis.Kataglyphis",
  "default-branch": "main",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "kataglyphis_rustprojecttemplate",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland"
  ],
  "modules": [
    {
      "name": "kataglyphis-binary",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p /app/bin /app/share/applications /app/share/icons/hicolor/256x256/apps",
        "sh -c 'for f in files/bin/*; do if [ -f \"$f\" ]; then install -D \"$f\" /app/bin/$(basename \"$f\"); chmod +x /app/bin/$(basename \"$f\"); fi; done'",
        "sh -c 'if [ -f files/share/applications/kataglyphis.desktop ]; then install -D files/share/applications/kataglyphis.desktop /app/share/applications/kataglyphis.desktop; fi'"
      ],
      "sources": [
        {
          "type": "file",
          "path": "../../target/release/kataglyphis_rustprojecttemplate",
          "dest": "files/bin"
        },
        {
          "type": "file",
          "path": "kataglyphis.desktop",
          "dest": "files/share/applications"
        },
        {
          "type": "file",
          "path": "icon.png",
          "dest": "files/share/icons/hicolor/256x256/apps"
        }
      ]
    }
  ]
}
